{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "../dist-electron",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "electron"]
  },
  "include": [
    "**/*.ts",
    "../src/types.ts",
    "../src/scanner/**/*.ts",
    "../src/scanner/**/*.json",
    "../src/domTracerEngine.ts",
    "../src/oastProviderProfile.ts",
    "../src/contentDiscoveryEngine.ts",
    "../src/specImport/index.ts",
    "../src/specImport/openApi.ts",
    "../src/specImport/postman.ts",
    "../src/specImport/graphqlSchema.ts",
    "../src/specImport/odata.ts",
    "../src/specImport/harSeed.ts",
    "../src/specImport/insomnia.ts",
    "../src/specImport/soapWsdl.ts",
    "../src/specImport/barrel.ts",
    "../src/spiders/ajaxSpiderEngine.ts",
    "../src/spiders/passiveLinkCrawler.ts",
    "../src/data/**/*.json",
    "../src/stats/**/*.ts",
    "../src/sbomEngine.ts",
    "../src/sbomFormats/**/*.ts",
    "../src/automation/**/*.ts",
    "../src/contextEngine.ts",
    "../src/authMethods/**/*.ts",
    "../src/users/**/*.ts",
    "../src/customPages.ts",
    "../src/antiCsrf/**/*.ts",
    "../src/modes/**/*.ts",
    "../src/replacer/**/*.ts",
    "../src/exploitTemplates/**/*.ts",
    "../src/aiTools/**/*.ts"
  ],
  "exclude": [
    "../src/components",
    "../src/App.tsx",
    "../src/main.tsx",
    "../src/apiGenerators",
    "../src/extensions/sampleExtensions"
  ]
}
